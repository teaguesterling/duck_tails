# name: test/sql/git_read_functions.test
# description: Test git_read and git_read_each functions
# group: [sql]

require duck_tails

require notwindows

# Use __BUILD_DIRECTORY__ to ensure we load the freshly built extension
statement ok
SET extension_directory='__BUILD_DIRECTORY__/extension';

statement ok
PRAGMA enable_verification

# Test basic git_read function with a simple file
query TITTITTTT
SELECT git_uri, mode, kind, is_text, encoding, size_bytes > 0 as has_size, truncated, 
       text IS NOT NULL as has_text, blob IS NULL as no_blob
FROM git_read('git://test/tmp/main-repo/README.md@HEAD')
----
git://test/tmp/main-repo/README.md@HEAD	33188	file	true	utf8	true	false	true	true

# Test git_read with non-existent file (should throw exception)
statement error
SELECT * FROM git_read('git://test/tmp/main-repo/non_existent_file.txt@HEAD')
----
file not found 'non_existent_file.txt' in commit 'HEAD'

# Test git_read with invalid reference (should throw exception)
statement error
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@invalid@@@ref')
----
unable to parse OID

# Test git_read with max_bytes parameter
query IT
SELECT size_bytes > 10 as original_larger, truncated 
FROM git_read('git://test/tmp/main-repo/README.md@HEAD', 10)
----
true	true

# Test git_read function overloads exist
statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD')

statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD', 1000)

statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD', 1000, 'auto')

statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD', 1000, 'auto', 'utf8')

statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD', 1000, 'auto', 'utf8', 'raw')

# Test git_read_each function with simple input (direct call works)
query T
SELECT kind FROM git_read('git://test/tmp/main-repo/README.md@HEAD')
----
file

# Verify schema has 16 columns (expanded schema)
query I
SELECT COUNT(*) FROM (
  DESCRIBE (SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD'))
)
----
16

# Test that git_read and git_read_each both execute properly
statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD');

statement ok
SELECT * FROM git_read('git://test/tmp/main-repo/README.md@HEAD')

# Issue #17: relative git:// URI combined with explicit repo_path named parameter
# should resolve the file inside the repository at repo_path, not against cwd.
query TT
SELECT kind, file_path
FROM git_read('git://README.md@HEAD', repo_path := 'test/tmp/main-repo')
----
file	README.md

# Same as above but for a different file in the same fixture repo, to confirm
# that repo_path + URI path composition works for arbitrary filenames.
query TT
SELECT kind, file_path
FROM git_read('git://app.js@HEAD', repo_path := 'test/tmp/main-repo')
----
file	app.js

# The git:// prefix is optional. A bare filesystem path + explicit repo_path
# should compose into the same lookup.
query TT
SELECT kind, file_path
FROM git_read('README.md', repo_path := 'test/tmp/main-repo')
----
file	README.md

# Reading a file from a nested directory under repo_path.
query TT
SELECT kind, file_path
FROM git_read('git://src/main.py@HEAD', repo_path := 'test/tmp/main-repo')
----
file	src/main.py

# Absolute URI path that matches repo_path is accepted (repo_path is redundant but consistent).
query T
SELECT kind
FROM git_read('git://test/tmp/main-repo/README.md@HEAD', repo_path := 'test/tmp/main-repo')
----
file

# Absolute URI path that disagrees with repo_path must be rejected — the two
# specifications are conflicting and silently preferring one would hide bugs.
statement error
SELECT * FROM git_read('git:///absolute/path/repo/file.txt@HEAD', repo_path := '/other/repo')
----
conflicting repository paths

# Issue #17 (LATERAL): git_read_each also honors repo_path for relative URIs.
query TT
WITH inputs(uri) AS (VALUES ('git://README.md@HEAD'), ('git://app.js@HEAD'))
SELECT i.uri, r.kind
FROM inputs i, LATERAL git_read_each(i.uri, repo_path := 'test/tmp/main-repo') r
ORDER BY i.uri
----
git://README.md@HEAD	file
git://app.js@HEAD	file

# LATERAL with bare filename (no git:// prefix) should compose under repo_path.
query T
WITH inputs(path) AS (VALUES ('README.md'))
SELECT r.kind
FROM inputs i, LATERAL git_read_each(i.path, repo_path := 'test/tmp/main-repo') r
----
file

# LATERAL: absolute URI that conflicts with repo_path surfaces as an error.
statement error
WITH inputs(uri) AS (VALUES ('git:///absolute/path/repo/file.txt@HEAD'))
SELECT r.kind
FROM inputs i, LATERAL git_read_each(i.uri, repo_path := '/other/repo') r
----
conflicting repository paths
